{
    "tools": [
        {
            "id": "ticker_indicators",
            "name": "Technical Indicators",
            "description": "prompts/ticker-indidcators-desc.md",
            "parameters": {
                "type": "object",
                "properties": {
                    "symbol": {
                        "type": "string",
                        "description": "The stock ticker symbol"
                    },
                    "indicators": {
                        "type": "array",
                        "items": {
                            "type": "string",
                            "enum": [
                                "RSI",
                                "MACD",
                                "SMA",
                                "EMA",
                                "BB"
                            ]
                        },
                        "description": "List of indicators to return. Omit to return all."
                    }
                },
                "required": [
                    "symbol"
                ]
            },
            "category": "finance",
            "allowed_agents": [
                "finance-agent",
                "stock-info-agent",
                "stock-screener-agent"
            ]
        },
        {
            "id": "ticker_peers",
            "name": "Ticker Peers",
            "description": "prompts/ticker-peers-desc.md",
            "parameters": {
                "type": "object",
                "properties": {
                    "symbol": {
                        "type": "string",
                        "description": "The stock ticker symbol"
                    },
                    "limit": {
                        "type": "integer",
                        "description": "Max number of peers to return.",
                        "default": 10
                    }
                },
                "required": [
                    "symbol",
                    "limit"
                ]
            },
            "category": "finance",
            "allowed_agents": [
                "finance-agent",
