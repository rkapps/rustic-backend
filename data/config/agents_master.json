{
    "agents": [
      {
        "id": "finance-agent",
        "name": "Finance Agent",
        "description": "Analyses stocks, tickers, ML signals and portfolios.",
        "execution": "single_agent",
        "system_prompt": "prompts/agents/finance-system.md",
        "tools": [
          "ticker_indicator",
          "ticker_peers",
          "ticker_price_history",
          "ticker_screening",
          "ticker_snapshot",
          "ticker_taxonomy"
          ],
        "model_assignment": {
          "default": { "provider": "anthropic", "model": "claude-sonnet-4-6" },
          "allowed": [
            { "provider": "anthropic", "model": "claude-sonnet-4-6" },
            { "provider": "anthropic", "model": "claude-opus-4-6" },
            { "provider": "openai",    "model": "gpt-5.4" },
            { "provider": "openai",    "model": "gpt-5.4-mini" },
            { "provider": "local",     "model": "llama3.1:8b" }
          ]
        },
        "conversation": {
          "default_strategy": "stateless",
          "allowed_strategies": ["stateless", "stateful"],
          "default_history_mode": "trimmed_full"
        }
      },
  
      {
        "id": "finance-orchestrator",
