FROM rust:1.92-alpine AS builder
WORKDIR /app
RUN apk add --no-cache \
    musl-dev \
    openssl-dev \
    openssl-libs-static \
    pkgconfig \
    g++ \
    cmake \
    make

COPY Cargo.toml Cargo.lock ./
COPY crates/ crates/
COPY bin/ bin/
RUN cargo build --release --bin rustic-ai-api

FROM alpine:latest
WORKDIR /app
RUN apk add --no-cache openssl ca-certificates
COPY --from=builder /app/target/release/rustic-ai-api .
EXPOSE 8080
CMD ["./rustic-ai-api"]